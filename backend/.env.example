# Supabase PostgreSQL (Transaction Pooler)
# Get these from: Supabase Dashboard → Project Settings → Database → Connection String
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEBUG=False

# File Uploads (local fallback — not used on Vercel; files go to Supabase Storage)
UPLOAD_DIR=./uploads

# Supabase Storage
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=AID_DOC
